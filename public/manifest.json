{
  "manifest_version": 3,
  "name": "Design.md Extractor",
  "version": "1.0.0",
  "description": "Extract DESIGN.md from any webpage using Gemini AI",
  "permissions": ["storage", "activeTab", "sidePanel", "contextMenus", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Open Design.md Extractor"
  },
  "icons": {
    "48": "icons/icon.png",
    "96": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
